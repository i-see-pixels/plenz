{
  "name": "promptlens",
  "private": true,
  "version": "1.1.0",
  "description": "Open-source browser extension for real-time AI prompt refinement.",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "build:chrome": "pnpm -C apps/extension build",
    "build:firefox": "pnpm -C apps/extension build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:ui-primitives": "node scripts/check-no-app-local-ui.mjs",
    "format": "turbo format",
    "test": "turbo test",
    "test:unit": "echo \"No unit tests are configured yet.\"",
    "type-check": "turbo type-check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/i-see-pixels/promptlens.git"
  },
  "bugs": {
    "url": "https://github.com/i-see-pixels/promptlens/issues"
  },
  "homepage": "https://github.com/i-see-pixels/promptlens",
  "devDependencies": {
    "turbo": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=9.0.0 <9.0.6": "9.0.6",
      "ajv@<6.14.0": "6.14.0"
    }
  }
}
